generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Prospect {
  id            Int       @id @default(autoincrement())
  uuid          String    @unique @default(cuid())

  // Imported from CSV
  name          String
  category      String?
  address       String?
  postal_code   String?
  city          String?
  country       String?
  phone         String?
  email         String?
  website       String?
  gm_link       String?
  rating        Float?
  reviews_count Int?
  opening_hours String?
  owner         String?
  facebook_url  String?
  instagram_url String?
  linkedin_url  String?

  // CRM fields
  status        String    @default("new")
  callback_at   DateTime?
  callback_note String?
  notes         String?
  list_name     String?

  documents     Document[]
  appointments  Appointment[]

  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
}

model Appointment {
  id          Int      @id @default(autoincrement())
  prospect_id Int
  prospect    Prospect @relation(fields: [prospect_id], references: [id], onDelete: Cascade)
  title       String
  date        DateTime
  duration    Int      // minutes, multiple of 15
  type        String   // "call" | "visio"
  meet_link   String?
  notes       String?
  status      String   @default("scheduled") // "scheduled" | "completed" | "cancelled"
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model Document {
  id          Int      @id @default(autoincrement())
  prospect_id Int
  prospect    Prospect @relation(fields: [prospect_id], references: [id], onDelete: Cascade)
  filename    String
  filepath    String
  category    String
  size        Int
  created_at  DateTime @default(now())
}

model EmailTemplate {
  id         Int      @id @default(autoincrement())
  name       String
  subject    String
  body       String
  category   String?
  language   String   @default("fr") // "fr" | "en"
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model List {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  is_visible Boolean  @default(true)
  created_at DateTime @default(now())
}

model Settings {
  id                 Int     @id @default(1)
  gmail_user         String  @default("")
  gmail_app_password String  @default("")
  sender_name        String  @default("")

  first_name         String  @default("Cantin")
  last_name          String  @default("Bartel")
  display_name       String  @default("Cantin Bartel")
  professional_title String  @default("Développeur web freelance")
  professional_title_en String @default("")
  business_name      String  @default("CB Web Artisan")
  contact_email      String  @default("cantinbartel.dev@gmail.com")
  phone              String  @default("")
  website_url        String  @default("https://fr.cantinbartel.dev")
  linkedin_url       String  @default("https://www.linkedin.com/in/cantin-bartel")
  instagram_url      String  @default("")
  facebook_url       String  @default("")
  whatsapp_url       String  @default("")
  github_url         String  @default("https://github.com/cantin-b")
  signature_enabled  Boolean @default(true)
  signature_logo_enabled Boolean @default(true)
  signature_custom_enabled Boolean @default(false)
  signature_visible_fields String @default("name,title,phone,email,website,linkedin,instagram,facebook,whatsapp,github")
  signature_html     String  @default("")
  ui_language        String  @default("en") // "en" | "fr" — CRM interface language
  content_language   String  @default("fr") // "en" | "fr" — templates + signature language
  password_hash      String  @default("")
}
